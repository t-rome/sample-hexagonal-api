APP_ENV=dev
APP_SECRET=change_me

###> symfony/messenger ###
# Pick one transport — comment out the others.
#
# Option 1: RabbitMQ (AMQP) — requires a running broker + worker process
#   Start worker: php bin/console messenger:consume domain_events -vv
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/domain_events
#
# Option 2: Doctrine (Postgres queue) — no extra broker needed, worker still required
# MESSENGER_TRANSPORT_DSN=doctrine://default
#
# Option 3: sync:// — handlers run inline, no broker or worker needed
# MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###
