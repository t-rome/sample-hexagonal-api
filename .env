APP_ENV=dev
APP_SECRET=change_me

###> symfony/messenger ###
# AMQP (RabbitMQ) — used in Docker (compose.yaml injects this automatically).
# For local dev outside Docker, start RabbitMQ separately and use the line below.
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/domain_events
###< symfony/messenger ###
